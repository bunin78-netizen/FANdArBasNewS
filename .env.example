# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel/Chat ID to publish to (e.g. @mychannel or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_id

# Admin Telegram user IDs (comma-separated) who can use admin commands
ADMIN_USER_IDS=123456789,987654321

# CoinGecko API (free tier, no key needed; fill for Pro tier)
COINGECKO_API_KEY=

# NewsAPI key (free key at https://newsapi.org) — optional
NEWS_API_KEY=

# CryptoPanic API key (optional, https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=

# ── Promo / Advertising settings ──────────────────────────────────────────────

# Name of the trading terminal you are promoting
PROMO_TERMINAL_NAME=MyTradingTerminal

# Referral / promo link to the terminal
PROMO_LINK=https://example.com/ref/your_id

# Short promo slogan shown in /start, /promo and inline button
PROMO_SLOGAN=Лучший терминал для торговли криптовалютой

# How often to auto-post a promo message to the channel (in minutes, 0 = disabled)
PROMO_INTERVAL_MINUTES=120

# ── Scheduler ─────────────────────────────────────────────────────────────────

# How often to auto-publish news (in minutes)
NEWS_INTERVAL_MINUTES=60

# How often to auto-publish price updates (in minutes)
PRICE_INTERVAL_MINUTES=30

# Top N coins to track for prices
TOP_COINS_COUNT=10
